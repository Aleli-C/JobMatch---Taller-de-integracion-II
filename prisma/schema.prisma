generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==============================
// MODELOS
// ==============================

model Usuario {
  rut
  nombre
  correo
  contrasena
  tipo_usuario
  latitud
  longitud
  direccion

  perfil
  publicaciones
  postulaciones
  guardados
  chats1
  chats2
  mensajesTx
  mensajesRx
  bloqueados
  bloqueadores
  reportesHechos
  reportesRecibidos
  historialEmpleador
  historialEmpleado
  calificaciones
  foros
  respuestas
}

model Perfil {
  foto
  habilidades
  experiencia
  nivel_insignias
  verificacion
  disponibilidad_hr

  usuario
}

model Ubicacion {
  ciudad
  comuna
  region
  latitud
  longitud

  publicaciones
}

model Categoria {
  nombre
  descripcion
  icono

  publicaciones
}

model Publicacion {
  titulo
  descripcion
  remuneracion
  tipo
  estado
  fecha_publicacion
  fecha_cierre
  icono

  usuario
  ubicacion
  categoria
  postulaciones
  guardados
  reportes
  historial
}

model Chat {
  creadoEn

  usuario1
  usuario2
  mensajes
}

model Mensajes {
  contenido
  enviadoEn

  chat
  remitente
  destinatario
}

model Bloqueo {
  fecha
  motivo

  bloqueador
  bloqueado
}

model Reportes {
  motivo
  fecha
  estado

  reportante
  reportado
  publicacion
}

model Postulacion {
  fecha
  estado

  usuario
  publicacion
}

model Guardados {
  fecha

  usuario
  publicacion
}

model Historial_trabajos {
  fechaInicio
  fechaFin
  descripcion

  empleador
  empleado
  publicacion
  calificaciones
}

model Calificacion {
  puntuacion
  comentario
  fecha

  historial
  autor
}

model Foro {
  titulo
  consulta
  fecha

  usuario
  respuestas
}

model Respuestas_foro {
  respuesta
  fecha

  foro
  usuario
}

// ==============================
// ENUMS
// ==============================

enum TipoUsuario {
}

enum TipoEnum {
}

enum EstadoEnum {
}

enum NivelInsignias {
}

enum EstadoReporte {
}

enum EstadoPostulacion {
}

enum Puntuacion {
}
